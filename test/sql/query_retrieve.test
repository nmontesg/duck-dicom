# wrong TLS credential filepaths
statement error
FROM query_dicom(
	host='localhost',
	port=4242,
	aetitle='ORTHANC',
	tls_ca_file='i/dont/exist',
	tls_key_file='test/tls/duckdb/duckdb.key',
	peer_ca_file='test/tls/duckdb/trusted.crt',
	query={'Modality': 'MR'});
