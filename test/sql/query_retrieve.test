	host='localhost',
	port=4242,
	aetitle='ORTHANC',
	tls_ca_file='i/dont/exist',
	tls_key_file='test/tls/duckdb/duckdb.key',
	peer_ca_file='test/tls/duckdb/trusted.crt',
	match_keys={'Modality': 'MR'},
	retrieve_keys=['StudyDescription']);
