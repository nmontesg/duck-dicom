# extract tag names
statement ok
SELECT tag_name(unnest(json_keys(dicom_content))::dicom_tag)
FROM read_dicom('test/test_data/IM_2381');

query I
SELECT tag_name(unnest(json_keys(dicom_content))::dicom_tag)
FROM read_dicom('test/test_data/IM_2381')
ORDER BY 1
LIMIT 5;
----
2001,1001
2001,1002
2001,1003
2001,1004
2001,1006

query I
SELECT tag_name(unnest(json_keys(dicom_content))::dicom_tag)
FROM read_dicom('test/test_data/IM_2381')
ORDER BY 1 DESC
LIMIT 5;
----
WindowWidth
WindowCenter
TransmitCoilName
TemporalPositionIdentifier
StudyTime

# comprehensive example
statement ok
SELECT 
    tag AS raw_tag,
    tag_name(tag) AS keyword,
    tag_group(tag) AS group_hex,
    tag_element(tag) AS element_hex
FROM (
    SELECT unnest(json_keys(dicom_content))::DICOM_TAG AS tag 
    FROM read_dicom('test/test_data/IM_2381')
);
