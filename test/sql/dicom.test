# name: test/sql/dicom.test
# description: test dicom extension
# group: [sql]

# before loading
statement error
SELECT read_dicom('/some/path/to/dicom');
----
Catalog Error: Scalar Function with name read_dicom does not exist!

statement error
CREATE SECRET (TYPE dicom, AETITLE 'my_aetitle', HOST 'localhost', PORT '42');
----
Invalid Input Error: Secret type 'dicom' not found

# with extension loaded
require dicom

require json

# =================== READ_DICOM unit tests ===================

# at least one argument needed
statement error
SELECT read_dicom();
----

# path must exists
statement error
SELECT read_dicom('non/existent/path');
----

# test loading DICOM files with and without extension
statement ok
FROM read_dicom('test/test_data/IM_2381');

statement ok
FROM read_dicom('test/test_data/000000.dcm');

# test loading glob patterns
statement ok
FROM read_dicom('test/test_data/*');

# test loading pixel data
statement ok
FROM read_dicom('test/test_data/*', load_pixel_data=true);

statement ok
FROM read_dicom('test/test_data/*', LOAD_PIXEL_DATA=true);

# test tag extraction
query II
SELECT path, dicom_content->'00080070'->'Value' FROM read_dicom('test/test_data/IM_2381');
----
test/test_data/IM_2381	["Philips Medical Systems"]

# =================== DICOM_TAG type tests ===================

statement ok
CREATE TABLE dicom_tags_test (id INTEGER, tag DICOM_TAG);

statement ok
INSERT INTO dicom_tags_test VALUES (1, {'group': '0x0008', 'elem': '0x012D'});

query II
FROM dicom_tags_test;
----
1	0008,012D

statement ok
INSERT INTO dicom_tags_test VALUES (1, '0008,0008'), (2, '8,8'), (3, '00080008');

statement ok
INSERT INTO dicom_tags_test VALUES (4, '0008,012D'), (5, '8,12D'), (6, '0008012D');

statement ok
INSERT INTO dicom_tags_test VALUES (7, '0008,012d'), (8, '8,12d'), (9, '0008012d');

# group too long
statement error
INSERT INTO dicom_tags_test VALUES (-1, '12345,0008');
----

# element too long
statement error
INSERT INTO dicom_tags_test VALUES (-1, '0008,12345');
----

# overall tag too short
statement error
INSERT INTO dicom_tags_test VALUES (-1, '000812');
----

# overall tag too long
statement error
INSERT INTO dicom_tags_test VALUES (-1, '000812345');
----

statement ok
SELECT unnest(json_keys(dicom_content))::dicom_tag FROM read_dicom('test/test_data/IM_2381');
